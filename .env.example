DEBUG=True

# ─── Security ─────────────────────────────────────────────
# Generate a strong random value for production; never commit real secrets.
SECRET_KEY=replace-with-a-long-random-string

# Local dev only: exposes POST /v1/auth/test-token (disable in production)
ENABLE_TEST_TOKEN_ENDPOINT=false

# ─── Server ───────────────────────────────────────────────
SERVER_NAME="whisper.api"
SERVER_HOST=http://localhost:7860

BACKEND_CORS_ORIGINS=[]

# ─── Database ─────────────────────────────────────────────
DATABASE_URL=sqlite:///./whisper.db
TEST_DATABASE_URL=sqlite:///./test.db

# ─── Whisper ──────────────────────────────────────────────
WHISPER_BINARY_PATH=./binary/whisper-cli
MODELS_DIR=./models
MAX_CONCURRENT_TRANSCRIPTIONS=2
MAX_AUDIO_UPLOAD_BYTES=52428800
MAX_AUDIO_DOWNLOAD_BYTES=52428800
# Safer default: no redirects on URL ingest (set true only if you trust your callers)
AUDIO_URL_FOLLOW_REDIRECTS=false
WHISPER_CLI_TIMEOUT_SEC=3600
FFMPEG_TIMEOUT_SEC=600

# ─── Streaming ────────────────────────────────────────────
STREAM_CHUNK_DURATION_MS=5000