---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";

interface NavItem {
  slug: string;
  title: string;
}

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title: string;
  description?: string;
  navItems: NavItem[];
  currentSlug: string;
  headings: Heading[];
  prevItem?: NavItem;
  nextItem?: NavItem;
  searchItems: {
    title: string;
    description?: string;
    slug: string;
    href: string;
  }[];
}

const { title, description, navItems, currentSlug, headings, prevItem, nextItem, searchItems } = Astro.props;
const active = currentSlug === "" ? "/docs" : `/docs/${currentSlug}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light" />
    <script is:inline>
      (() => {
        const root = document.documentElement;
        root.style.backgroundColor = "#EAEFEF";
        root.style.color = "#25343F";
        root.style.colorScheme = "light";
      })();
    </script>
    <ClientRouter />
    <title>{title} | Whisper API Docs</title>
    {description && <meta name="description" content={description} />}
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="shortcut icon" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>

  <body>
    <header class="sticky top-0 z-40 border-b border-[var(--line)] bg-[var(--panel)] shadow-[var(--shadow-sm)]">
      <div class="mx-auto flex h-16 w-full max-w-[1500px] items-center justify-between px-3 sm:px-4 lg:px-5">
        <a href="/docs" class="flex items-center gap-3 text-lg font-bold text-[var(--text)] transition-colors hover:opacity-80">
          <div class="flex h-8 w-8 items-center justify-center rounded-lg border border-[var(--line)] bg-[var(--bg)] text-sm font-bold text-[var(--text)]">
            W
          </div>
          <span>Whisper API</span>
        </a>

        <div class="flex items-center gap-3">
          <div class="relative hidden w-[320px] md:block">
            <input
              id="docs-search-input"
              type="search"
              placeholder="Search docs..."
              autocomplete="off"
              data-search-items={JSON.stringify(searchItems)}
              class="w-full rounded-lg border border-[var(--line)] bg-[var(--bg)] px-4 py-2 text-[var(--text)] placeholder-[var(--muted)] transition-all focus:border-[var(--text)] focus:outline-none focus:ring-2 focus:ring-[var(--line)]"
            />
            <div id="docs-search-results" class="hidden absolute right-0 top-[calc(100%+0.35rem)] z-50 max-h-80 w-[360px] overflow-y-auto rounded-lg border border-[var(--line)] bg-[var(--panel)] p-1 shadow-[var(--shadow-lg)]"></div>
          </div>

          <a
            href="https://github.com/innovatorved/whisper.api"
            aria-label="GitHub"
            target="_blank"
            rel="noreferrer"
            class="inline-flex h-10 w-10 items-center justify-center rounded-lg border border-[var(--line)] text-[var(--text)] transition-all hover:opacity-80"
          >
            <svg viewBox="0 0 24 24" class="h-5 w-5 fill-current">
              <path d="M12 2C6.48 2 2 6.58 2 12.23c0 4.52 2.87 8.35 6.84 9.7.5.1.66-.22.66-.49 0-.24-.01-1.04-.01-1.88-2.78.62-3.37-1.2-3.37-1.2-.45-1.18-1.11-1.5-1.11-1.5-.91-.64.07-.63.07-.63 1 .08 1.53 1.06 1.53 1.06.9 1.57 2.36 1.12 2.94.86.09-.67.35-1.12.63-1.38-2.22-.26-4.56-1.14-4.56-5.08 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.3.1-2.71 0 0 .84-.28 2.75 1.05A9.27 9.27 0 0 1 12 6.9c.85 0 1.71.12 2.51.35 1.9-1.33 2.74-1.05 2.74-1.05.55 1.41.2 2.45.1 2.71.64.72 1.03 1.63 1.03 2.75 0 3.95-2.34 4.82-4.57 5.07.36.32.68.95.68 1.92 0 1.39-.01 2.5-.01 2.84 0 .27.17.59.67.49A10.28 10.28 0 0 0 22 12.23C22 6.58 17.52 2 12 2Z" />
            </svg>
          </a>
        </div>
      </div>
    </header>

    <main class="mx-auto w-full max-w-[1500px] px-3 py-6 sm:px-4 lg:px-5">
      <div class="grid grid-cols-1 gap-5 lg:grid-cols-[240px_minmax(0,1fr)_240px]">
        <aside class="hidden lg:block">
          <nav class="sticky top-24 space-y-1">
            <div class="mb-6 rounded-lg border border-[var(--line)] bg-[var(--bg)] px-4 py-3">
              <p class="text-xs font-bold uppercase tracking-widest text-[var(--text)]">Documentation</p>
            </div>
            {navItems.map((item) => {
              const href = item.slug === "" ? "/docs" : `/docs/${item.slug}`;
              const isActive = href === active;
              return (
                <a
                  href={href}
                  class={`block rounded-lg px-4 py-2.5 text-sm font-medium transition-all ${
                    isActive
                      ? "border border-[var(--line)] bg-[var(--bg)] text-[var(--text)]"
                      : "border border-transparent text-[var(--text)] hover:bg-[var(--bg)]"
                  }`}
                >
                  {item.title}
                </a>
              );
            })}
          </nav>
        </aside>

        <article class="prose min-w-0 max-w-none">
          <details class="mb-8 rounded-lg border border-[var(--line)] bg-[var(--panel)] p-4 shadow-[var(--shadow-md)] lg:hidden">
            <summary class="flex cursor-pointer items-center gap-2 font-semibold text-[var(--text)]">
              <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20">
                <path
                  fill-rule="evenodd"
                  d="M3 5a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm0 5a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm0 5a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1z"
                  clip-rule="evenodd"
                ></path>
              </svg>
              Navigation
            </summary>
            <nav class="mt-4 space-y-2">
              {navItems.map((item) => {
                const href = item.slug === "" ? "/docs" : `/docs/${item.slug}`;
                const isActive = href === active;
                return (
                  <a
                    href={href}
                    class={`block rounded-lg px-4 py-2 text-sm font-medium transition-all ${
                      isActive
                        ? "border border-[var(--line)] bg-[var(--bg)] text-[var(--text)]"
                        : "text-[var(--text)] hover:bg-[var(--bg)]"
                    }`}
                  >
                    {item.title}
                  </a>
                );
              })}
            </nav>
          </details>

          <slot />

          {(prevItem || nextItem) && (
            <div class="not-prose mt-10 grid gap-3 border-t border-[var(--line)] pt-5 sm:grid-cols-2">
              {prevItem ? (
                <a
                  href={prevItem.slug === "" ? "/docs" : `/docs/${prevItem.slug}`}
                  class="card-bottom-line group rounded-md border border-[var(--line)] bg-[var(--panel)] px-4 py-3 transition-all"
                >
                  <p class="mb-1 text-[11px] font-semibold uppercase tracking-[0.08em] text-[var(--muted)]">← Previous</p>
                  <p class="text-sm font-semibold text-[var(--text)]">{prevItem.title}</p>
                </a>
              ) : (
                <div></div>
              )}

              {nextItem && (
                <a
                  href={nextItem.slug === "" ? "/docs" : `/docs/${nextItem.slug}`}
                  class="card-bottom-line group rounded-md border border-[var(--line)] bg-[var(--panel)] px-4 py-3 text-right transition-all"
                >
                  <p class="mb-1 text-[11px] font-semibold uppercase tracking-[0.08em] text-[var(--muted)]">Next →</p>
                  <p class="text-sm font-semibold text-[var(--text)]">{nextItem.title}</p>
                </a>
              )}
            </div>
          )}
        </article>

        <aside class="hidden lg:block">
          <div class="sticky top-24 rounded-lg border border-[var(--line)] bg-[var(--panel)] p-4 shadow-[var(--shadow-sm)]">
            <p class="mb-4 text-xs font-bold uppercase tracking-widest text-[var(--text)]">On This Page</p>
            <nav class="space-y-2 text-sm" id="toc-nav">
              {headings
                .filter((h) => h.depth <= 3)
                .map((heading) => (
                  <a
                    href={`#${heading.slug}`}
                    data-heading={heading.slug}
                    class={`block transition-colors ${
                      heading.depth === 1
                        ? "toc-link toc-depth-1 font-semibold text-[var(--text)] hover:opacity-80"
                        : heading.depth === 2
                          ? "toc-link toc-depth-2 pl-4 font-medium text-[var(--text)] hover:opacity-80"
                          : "toc-link toc-depth-3 pl-8 text-[var(--muted)] hover:opacity-80"
                    }`}
                  >
                    {heading.text}
                  </a>
                ))}
            </nav>
          </div>
        </aside>
      </div>
    </main>

    <script is:inline>
      (() => {
        const activeClass = "is-active";

        const initToc = () => {
          const tocNav = document.getElementById("toc-nav");
          if (!tocNav || tocNav.dataset.tocReady === "true") return;

          const tocLinks = Array.from(tocNav.querySelectorAll(".toc-link"));
          if (!tocLinks.length) return;

          tocNav.dataset.tocReady = "true";

          const setActive = (slug) => {
            tocLinks.forEach((link) => {
              const linkSlug = link.getAttribute("data-heading");
              link.classList.toggle(activeClass, linkSlug === slug);
            });
          };

          const slugFromHash = () => window.location.hash.replace(/^#/, "");

          const smoothScrollToHeading = (slug) => {
            const target = document.getElementById(slug);
            if (!target) return;

            const headerOffset = 96;
            const targetTop = target.getBoundingClientRect().top + window.scrollY - headerOffset;
            const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

            window.scrollTo({
              top: Math.max(targetTop, 0),
              behavior: reducedMotion ? "auto" : "smooth",
            });
          };

          tocLinks.forEach((link) => {
            link.addEventListener("click", (event) => {
              const slug = link.getAttribute("data-heading");
              if (!slug) return;

              event.preventDefault();
              setActive(slug);
              smoothScrollToHeading(slug);
              window.history.pushState(null, "", `#${slug}`);
            });
          });

          const headingElements = tocLinks
            .map((link) => link.getAttribute("data-heading"))
            .filter(Boolean)
            .map((slug) => document.getElementById(slug))
            .filter(Boolean);

          if (headingElements.length) {
            const observer = new IntersectionObserver(
              (entries) => {
                const visible = entries
                  .filter((entry) => entry.isIntersecting)
                  .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];

                if (visible?.target?.id) {
                  setActive(visible.target.id);
                }
              },
              {
                rootMargin: "-20% 0px -65% 0px",
                threshold: [0.1, 0.5, 1],
              }
            );

            headingElements.forEach((heading) => observer.observe(heading));
          }

          setActive(slugFromHash() || tocLinks[0].getAttribute("data-heading") || "");

          window.addEventListener("hashchange", () => {
            const slug = slugFromHash();
            if (slug) setActive(slug);
          });
        };

        document.addEventListener("astro:page-load", initToc);
        initToc();

        const initSearch = () => {
          const input = document.getElementById("docs-search-input");
          const results = document.getElementById("docs-search-results");
          if (!(input instanceof HTMLInputElement) || !(results instanceof HTMLDivElement)) return;
          if (input.dataset.searchReady === "true") return;

          input.dataset.searchReady = "true";

          const allItems = JSON.parse(input.dataset.searchItems || "[]");
          let activeIndex = -1;
          let matches = [];

          const normalize = (value) => String(value || "").toLowerCase().trim();

          const closeResults = () => {
            results.classList.add("hidden");
            results.innerHTML = "";
            activeIndex = -1;
          };

          const openResults = () => {
            results.classList.remove("hidden");
          };

          const renderMatches = () => {
            results.innerHTML = "";

            if (!matches.length) {
              const empty = document.createElement("p");
              empty.className = "px-3 py-2 text-sm text-[var(--muted)]";
              empty.textContent = "No results found.";
              results.appendChild(empty);
              openResults();
              return;
            }

            matches.forEach((item, index) => {
              const link = document.createElement("a");
              link.href = item.href;
              link.className = "search-result-item block rounded-md px-3 py-2";
              if (index === activeIndex) link.classList.add("is-active");

              const titleEl = document.createElement("p");
              titleEl.className = "m-0 text-sm font-semibold text-[var(--text)]";
              titleEl.textContent = item.title;
              link.appendChild(titleEl);

              if (item.description) {
                const descEl = document.createElement("p");
                descEl.className = "m-0 mt-0.5 text-xs text-[var(--muted)]";
                descEl.textContent = item.description;
                link.appendChild(descEl);
              }

              results.appendChild(link);
            });

            openResults();
          };

          const updateSearch = (rawQuery) => {
            const query = normalize(rawQuery);
            if (!query) {
              closeResults();
              return;
            }

            matches = allItems
              .filter((item) => {
                const haystack = normalize(`${item.title} ${item.description || ""} ${item.slug}`);
                return haystack.includes(query);
              })
              .slice(0, 8);

            activeIndex = matches.length ? 0 : -1;
            renderMatches();
          };

          input.addEventListener("input", () => {
            updateSearch(input.value);
          });

          input.addEventListener("focus", () => {
            if (input.value.trim()) updateSearch(input.value);
          });

          input.addEventListener("keydown", (event) => {
            if (results.classList.contains("hidden") || !matches.length) return;

            if (event.key === "ArrowDown") {
              event.preventDefault();
              activeIndex = (activeIndex + 1) % matches.length;
              renderMatches();
            }

            if (event.key === "ArrowUp") {
              event.preventDefault();
              activeIndex = (activeIndex - 1 + matches.length) % matches.length;
              renderMatches();
            }

            if (event.key === "Enter" && activeIndex >= 0) {
              event.preventDefault();
              window.location.href = matches[activeIndex].href;
            }

            if (event.key === "Escape") {
              closeResults();
            }
          });

          document.addEventListener("click", (event) => {
            const target = event.target;
            if (!(target instanceof Node)) return;
            if (!results.contains(target) && target !== input) {
              closeResults();
            }
          });
        };

        document.addEventListener("astro:page-load", initSearch);
        initSearch();
      })();
    </script>
  </body>
</html>
